[ext_resource type="PackedScene" uid="uid://bjpdybxj6pn7q" path="res://assets/MagicVFX/assets/BinbunVFX/magic_projectiles/effects/mprojectile_basic/mprojectile_basic_vfx_01.tscn" id="3"]

[sub_resource type="CapsuleShape3D" id="arrow_shape"]
radius = 0.05
