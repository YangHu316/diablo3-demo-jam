script = ExtResource("1")

[node name="ModelPivot" type="Node3D" parent="."]
; Arrow.gd 用 -basis.z 作为飞行方向(Godot 默认 forward)。
; 经实测 SM_Arrow_01.fbx 在 Synty post_import 后箭尖朝向 +Z;
; 所以这里绕 Y 转 180° 让箭尖朝 -Z(Godot forward),与飞行方向一致。
; 若再次发现箭尖方向不对,在编辑器 Inspector 调 ModelPivot 的 rotation:
;   - 朝 -Z (Godot forward,默认): rotation = (0, 180, 0)  ← 当前
;   - 朝 +Z (Synty 原始):           rotation = (0, 0, 0)
;   - 朝 +X:                        rotation = (0, -90, 0)
;   - 朝 -X:                        rotation = (0, 90, 0)
transform = Transform3D(-1, 0, 0, 0, 1, 0, 0, 0, -1, 0, 0, 0)

[node name="SM_Arrow_01" parent="ModelPivot" instance=ExtResource("2")]

[node name="CollisionShape3D" type="CollisionShape3D" parent="."]
