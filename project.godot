; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="ARPG 3C Demo"
run/main_scene="res://scenes/levels/level_02_play.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
CombatManager="*res://scripts/autoload/combat_manager.gd"
DataTables="*res://scripts/autoload/data_tables.gd"
ProgressionManager="*res://scripts/autoload/progression_manager.gd"
Inventory="*res://scripts/autoload/inventory.gd"
FocusResource="*res://scripts/autoload/focus_resource.gd"
DamageNumberPool="*res://scripts/autoload/damage_number_pool.gd"
CombatJuiceManager="*res://scripts/autoload/combat_juice_manager.gd"
SpawnManager="*res://scripts/autoload/spawn_manager.gd"
LootManager="*res://scripts/autoload/loot_manager.gd"
AnimLib="*res://scripts/autoload/anim_lib.gd"
RiftManager="*res://scripts/autoload/rift_manager.gd"
Sfx="*res://scripts/autoload/sfx_manager.gd"
SfxBind="*res://scripts/autoload/sfx_binder.gd"
TowerBuffManager="*res://scripts/autoload/tower_buff_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

; V3.10:从 4K(3840×2160 + FSR2 0.67x)降到 1080p 原生,4 个人电脑都卡的根因。
; 4K 像素 = 1080p 的 4x,即使 FSR2 缩到 67% 内部仍按 ~2570 渲染,低端 GPU 顶不住。
; 1080p 原生 + 无 FSR + 无 MSAA = 兼容低端机的稳定 60fps 配置。
scaling_3d/mode=0
scaling_3d/scale=1.0
lights_and_shadows/directional_shadow/size=2048
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=1
anti_aliasing/quality/msaa_3d=0

[filesystem]

import/blender/enabled=false

[gui]

theme/custom="res://default_theme.tres"
theme/custom_font="res://assets/fonts/NotoSansSC-Regular.ttf"

